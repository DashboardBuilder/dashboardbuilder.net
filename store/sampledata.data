datalabel><filter>true</filter><dropdown>false</dropdown><legposition/><xaxis>XLS:{col}X1{/col}{data}0,1,2,3,4,5{/data}</xaxis><yaxis>XLS:{col}Y1{/col}{data}1.5,1,1.3,0.7,0.8,0.9{/data}</yaxis><xmodel/><xsort/><ymodel/><ysort/><sql>SELECT strftime('%Y-%m',o.shippeddate) as Session, sum(d.quantity) as Quantity, sum(d.UnitPrice) as 'Unit Price' from OrderDetails d, orders o where o.orderid = d.orderid group by strftime('%Y-%m',o.orderdate) limit 50 </sql><size/><maptype/><text/><tracename>Sales</tracename><yntitle/><color>#ff0000</color><type>line</type><refresh>0</refresh><streaming>n</streaming><forecast>0</forecast><xaxis>XLS:{col}X2{/col}{data}0,1,2,3,4,5{/data}</xaxis><xsort/><xmodel/><type>line</type><yaxis>XLS:{col}Y2{/col}{data}1,0.5,0.7,-1.2,0.3,0.4{/data}</yaxis><ysort/><ymodel/><tracename>Quantity</tracename><yntitle/><color>#00df00</color><forecast>0</forecast><side>left</side><json/><border_color/><borderwidth>0</borderwidth><tablefontsize>9</tablefontsize><total_width>1</total_width><total_show>false</total_show><smartquery>false</smartquery><csvdata>false</csvdata><plot>dynamic</plot></col><col><source>upload</source><rdbms>sqlite</rdbms><servername/><ssl/><username/><password/><dbname>../data/Northwind.db</dbname><dbconnected>1</dbconnected><file>../data/combination-chart.xlsx</file><xaxis>XLS:{col}Month{/col}{data}Jan,Feb,Mar,Apr,May,Jun,Jul,Aug,Sep,Oct,Nov,Dec{/data}</xaxis><yaxis>XLS:{col}Profit{/col}{data}3574,4708,5332,6693,8843,12347,15180,11198,9789,9846,6620,5085{/data}</yaxis><sql>select c.categoryname, sum(a.quantity) as 'Sales 1997', sum(a.quantity)+1000 as 'Sales 1998' from products b, OrderDetails a, categories c where a.productid = b.productid and c.categoryid = b.categoryid group by c.categoryid order by c.categoryid </sql><size/><maptype/><text/><tracename>Sales 1997</tracename><color>#1A1DFF</color><type>line</type><title/><name>7</name><xaxistitle/><yaxistitle/><height>0</height><width>0</width><showgrid>true</showgrid><showline>true<